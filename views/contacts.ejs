<!-- _________________________________________________________________________Main Desgin All Contact -->
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>All Contacts</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
    <!-- ✅ no /public prefix -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
    />
  </head>
  <body>
    <div class="container mt-5">
      <div class="card">
        <div
          class="card-header bg-primary text-white d-flex justify-content-between align-items-center"
        >
          <h4 class="mb-0">All Contacts</h4>
          <a href="/add_contact" class="btn btn-success">+ Add New</a>
        </div>

        <div class="card-body">
          <table class="table table-striped table-bordered">
            <thead class="table-light">
              <tr>
                <th>#</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (contacts && contacts.length > 0) { %> <%
              contacts.forEach((c, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><%= c.first %></td>
                <td><%= c.last %></td>
                <td><%= c.email %></td>
                <td><%= c.phone %></td>
                <td>
                  <a
                    href="/show_contact/<%= c.id %>"
                    class="btn btn-info btn-sm"
                  >
                    <i class="bi bi-eye"></i>
                  </a>
                  <a
                    href="/update_contact/<%= c.id %>"
                    class="btn btn-warning btn-sm"
                  >
                    <i class="bi bi-pencil"></i>
                  </a>
                  <a
                    href="/delete_contact/<%= c.id %>"
                    class="btn btn-danger btn-sm"
                    onclick="return confirm('Delete this contact?')"
                  >
                    <i class="bi bi-x"></i>
                  </a>
                </td>
              </tr>
              <% }) %> <% } else { %>
              <tr>
                <td colspan="6" class="text-center text-muted">
                  No contacts available
                </td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </body>
</html>
